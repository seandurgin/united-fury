*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Secrets, tokens, env files — defense in depth
.env
.env.*
*.env
*_token.json
*_token_*.json
google_token*.json
ms_token*.json
plaid_tokens*.json
credentials.json
client_secret*.json

# Generated artifacts and exports
*.pem
*.key
*.crt

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
