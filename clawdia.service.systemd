[Unit]
Description=Clawdia - Personal AI Assistant
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/clawdia
EnvironmentFile=/etc/clawdia/env
ExecStart=/opt/clawdia/venv/bin/python3 bot_new.py
Restart=always
RestartSec=10
TimeoutStopSec=10
KillMode=mixed

[Install]
WantedBy=multi-user.target
